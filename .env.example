# Backend API (external REST). Axios appends these paths when not calling same-origin `/api/*`.
# Next.js uses NEXT_PUBLIC_* (not Create React App’s REACT_APP_*).
NEXT_PUBLIC_API_URL=https://api.example.com

# --- OTP auth (NextAuth + mobile API) ---
# Public API root including version prefix. Browser calls send-otp from here.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001/api/v1
# Server-side verify URL (authorize). Use 127.0.0.1 if NEXT_PUBLIC uses 0.0.0.0.
# API_INTERNAL_BASE_URL=http://127.0.0.1:3001/api/v1
# Override verify path if your backend differs (default POST .../auth/verify-otp with { mobile, otp }).
# AUTH_VERIFY_OTP_PATH=/auth/verify-otp
# Required for NextAuth / JWT (generate: openssl rand -base64 32)
AUTH_SECRET=
# Optional; inferred in dev with trustHost
# AUTH_URL=http://localhost:3000

# Google Maps — enable “Maps JavaScript API” + “Places API” for autocomplete on home hero pickup field.
NEXT_PUBLIC_GOOGLE_MAP_KEY=

# Optional: API request timeout in ms (default 20000)
# NEXT_PUBLIC_API_TIMEOUT_MS=20000

# Demo / dev only – never commit real secrets
# NEXT_PUBLIC_DEMO_OTP=4768
# NEXT_PUBLIC_SUPPORT_PHONE=9065847341

# WhatsApp wa.me (optional; falls back to SUPPORT_PHONE). Use full number with country code, e.g. 919065847341
# NEXT_PUBLIC_WHATSAPP_NUMBER=

# Site / brand (optional)
# Canonical origin for OG tags, JSON-LD, sitemap (no trailing slash). Required in production for correct share previews.
# NEXT_PUBLIC_SITE_URL=https://www.goliftngo.com
# NEXT_PUBLIC_TWITTER_HANDLE=@liftngo
# Social profiles — defaults use @liftngo-style URLs; set to your real channels in production
# NEXT_PUBLIC_SOCIAL_X=https://x.com/yourapp
# NEXT_PUBLIC_SOCIAL_TWITTER=https://x.com/yourapp
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/@yourapp
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/profile.php?id=61578755032262
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/liftngo-logistics
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/liftngo_goods_transfer/

# Google Search Console verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-meta-tag-content

# Google Analytics 4 — fire `book_now_click`, `whatsapp_click`, `form_submit`, etc. when set
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Liftngo chatbot (OpenAI + optional Google Sheets) ---
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional: booking redirect path returned when user confirms (default /book-delivery)
# NEXT_PUBLIC_CHAT_BOOKING_PATH=/book-delivery
#
# Google Sheets — pick ONE approach:
#
# A) No Google Cloud: Google Apps Script Web App URL (script bound to your spreadsheet).
#    Deploy doPost that accepts JSON: kind "lead" | "chat_log" (see src/lib/sheetsBridge.ts).
# APPS_SCRIPT_SHEETS_URL=https://script.google.com/macros/s/.../exec
#
# B) Service account (requires Google Cloud / IAM):
#    Tabs: Leads (timestamp,name,phone,query,source) + ChatLogs (session_id,user_message,bot_response,timestamp)
#    Share sheet with service account client_email as Editor.
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...single-line JSON...}
